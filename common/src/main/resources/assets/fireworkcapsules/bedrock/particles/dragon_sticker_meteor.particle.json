{
    "format_version": "1.10.0",
    "particle_effect": {
        "description": {
            "identifier": "fireworkcapsules:dragon_sticker_meteor",
            "basic_render_parameters": {
                "material": "particles_alpha",
                "texture": "fireworkcapsules:textures/particles/dragon_sticker"
            }
        },
        "curves": {
            "variable.age": {
                "type": "linear",
                "input": "v.emitter_age",
                "horizontal_range": "v.emitter_lifetime",
                "nodes": [0, 3]
            }
        },
        "components": {
            "minecraft:emitter_initialization": {
                "creation_expression": "variable.random_1 = math.random(0, 1);variable.random_2 = math.random(0, 1);variable.random_3 = math.random(0, 1);variable.random_4 = math.random(0, 1);"
            },
            "minecraft:emitter_rate_steady": {
                "spawn_rate": 150,
                "max_particles": 1000
            },
            "minecraft:emitter_lifetime_once": {
                "active_time": 3
            },
            "minecraft:emitter_shape_point": {
                "offset": ["v.age * 0.05 * v.random_1 + (v.random_3 - 0.5) * 3", "q.entity_height * 3 - (v.age * 1.5)", "-v.age * 0.05 * v.random_2 + (v.random_4 - 0.5) * 3"],
                "direction": ["-v.particle_random_3 * v.random_1", 1, "v.particle_random_4 * v.random_2"]
            },
            "minecraft:particle_lifetime_expression": {
                "max_lifetime": "v.particle_random_1 * 2.2"
            },
            "minecraft:particle_initial_spin": {
                "rotation": "v.particle_random_1 * 360"
            },
            "minecraft:particle_initial_speed": 0.5,
            "minecraft:particle_motion_dynamic": {
                "linear_drag_coefficient": 0.2
            },
            "minecraft:particle_appearance_billboard": {
                "size": ["0.2 * (v.particle_random_1 * 2.2 - v.particle_age)", "0.2 * (v.particle_random_1 * 2.2 - v.particle_age)"],
                "facing_camera_mode": "rotate_xyz",
                "uv": {
                    "texture_width": 16,
                    "texture_height": 16,
                    "uv": [0, 0],
                    "uv_size": [16, 16]
                }
            },
            "minecraft:particle_appearance_tinting": {
                "color": [1, 1, 1, 1]
            }
        }
    }
}