{
    "format_version": "1.10.0",
    "particle_effect": {
        "description": {
            "identifier": "fireworkcapsules:fire_sticker",
            "basic_render_parameters": {
                "material": "particles_alpha",
                "texture": "minecraft:textures/particles/flame"
            }
        },
        "components": {
            "minecraft:emitter_rate_steady": {
                "spawn_rate": 150,
                "max_particles": 600
            },
            "minecraft:emitter_lifetime_once": {
                "active_time": 3
            },
            "minecraft:emitter_shape_point": {
                "offset": [0, "q.entity_height * 0.5", 0],
                "direction": [
                    "math.cos(math.floor(v.particle_random_1 * 5) * 72 + 20) + v.particle_random_3 * 0.15",
                    "math.sin(math.floor(v.particle_random_1 * 5) * 72 + 20) + v.particle_random_4 * 0.15",
                    0
                ]
            },
            "minecraft:particle_lifetime_expression": {
                "max_lifetime": "math.random(0.8, 1.2)"
            },
            "minecraft:particle_initial_speed": "1.5 * math.clamp(q.entity_size / 1.5, 1, 3)",
            "minecraft:particle_motion_dynamic": {
                "linear_drag_coefficient": 0.25
            },
            "minecraft:particle_appearance_billboard": {
                "size": ["0.3 * math.clamp(q.entity_size / 4, 1, 2)", "0.3 * math.clamp(q.entity_size / 4, 1, 2)"],
                "facing_camera_mode": "rotate_xyz",
                "uv": {
                    "texture_width": 8,
                    "texture_height": 8,
                    "uv": [0, 0],
                    "uv_size": [8, 8]
                }
            }
        }
    }
}