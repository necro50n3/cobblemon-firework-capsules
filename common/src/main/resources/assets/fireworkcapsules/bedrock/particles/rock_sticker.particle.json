{
	"format_version": "1.10.0",
	"particle_effect": {
		"description": {
			"identifier": "fireworkcapsules:rock_sticker",
			"basic_render_parameters": {
				"material": "particles_alpha",
				"texture": "fireworkcapsules:textures/particles/rock_sticker"
			}
		},
		"components": {
			"minecraft:emitter_rate_steady": {
				"spawn_rate": "30 * math.clamp(q.entity_size / 1.5, 1, 4)",
				"max_particles": "60 * math.clamp(q.entity_size / 1.5, 1, 4)"
			},
			"minecraft:emitter_lifetime_once": {
				"active_time": 1
			},
			"minecraft:emitter_shape_sphere": {
				"offset": [0, "q.entity_height * 1.0", 0],
				"radius": "math.max(q.entity_width * 2, 1)",
				"surface_only": true,
				"direction": [0, -1, 0]
			},
			"minecraft:particle_lifetime_expression": {
				"max_lifetime": "1 + math.random(0.5, 1.5)"
			},
			"minecraft:particle_initial_speed": 2,
			"minecraft:particle_motion_dynamic": {
				"linear_acceleration": [0, -5, 0],
				"linear_drag_coefficient": 0.5
			},
			"minecraft:particle_appearance_billboard": {
				"size": ["0.3 * math.clamp(q.entity_size / 4, 1, 2)", "0.3 * math.clamp(q.entity_size / 4, 1, 2)"],
				"facing_camera_mode": "rotate_xyz",
				"uv": {
					"texture_width": 16,
					"texture_height": 64,
					"uv": [0, "16 * math.floor(variable.particle_random_1 * 4)"],
					"uv_size": [16, 16]
				}
			},
            "minecraft:particle_motion_collision": {
                "collision_drag": 1,
                "collision_radius": 0.2
            }
		}
	}
}