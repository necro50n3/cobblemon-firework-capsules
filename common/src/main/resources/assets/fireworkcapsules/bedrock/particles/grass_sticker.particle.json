{
    "format_version": "1.10.0",
    "particle_effect": {
        "description": {
            "identifier": "fireworkcapsules:grass_sticker",
            "basic_render_parameters": {
                "material": "particles_alpha",
                "texture": "fireworkcapsules:textures/particles/grass_sticker"
            }
        },
        "curves": {
            "variable.age": {
                "type": "linear",
                "input": "v.particle_age",
                "horizontal_range": "v.particle_lifetime",
                "nodes": [0.1, 3]
            }
        },
        "components": {
            "minecraft:emitter_rate_steady": {
                "spawn_rate": "30 * math.clamp(q.entity_size / 1.5, 1, 4)",
                "max_particles": "60 * math.clamp(q.entity_size / 1.5, 1, 4)"
            },
            "minecraft:emitter_lifetime_once": {
                "active_time": 1
            },
            "minecraft:emitter_shape_point": {
                "direction": [0, "q.entity_height * 1.2", 0]
            },
            "minecraft:particle_lifetime_expression": {
                "max_lifetime": "4 + math.random(1, 2)"
            },
            "minecraft:particle_initial_spin": {
                "rotation": "v.particle_random_1 * 360",
                "rotation_rate": "(v.particle_random_2 - 0.5) * 180"
            },
            "minecraft:particle_motion_parametric": {
                "relative_position": [
                    "math.sin(v.particle_age * 90 + v.particle_random_1 * 360) * 0.5 + (v.particle_random_2 - 0.5) * 2 * math.max(1, q.entity_size / 1.5)",
                    "v.particle_age * -0.4 + q.entity_height * 1.2",
                    "(v.particle_random_3 - 0.5) * 2 * math.max(1, q.entity_size / 1.5)"]
            },
            "minecraft:particle_appearance_billboard": {
                "size": ["0.35 * math.clamp(q.entity_size / 4, 1, 2)", "0.35 * math.clamp(q.entity_size / 4, 1, 2)"],
                "facing_camera_mode": "rotate_xyz",
                "uv": {
                    "texture_width": 16,
                    "texture_height": 48,
                    "uv": [0, "16 * math.floor(variable.particle_random_1 * 3)"],
                    "uv_size": [16, 16]
                }
            }
        }
    }
}