{
    "format_version": "1.10.0",
    "particle_effect": {
        "description": {
            "identifier": "fireworkcapsules:relic_sticker",
            "basic_render_parameters": {
                "material": "particles_alpha",
                "texture": "fireworkcapsules:textures/particles/relic_sticker"
            }
        },
        "components": {
            "minecraft:emitter_rate_instant": {
                "num_particles": 80
            },
            "minecraft:emitter_lifetime_once": {
                "active_time": 1
            },
            "minecraft:emitter_shape_point": {
                "offset": [0, "q.entity_height * 0.5", 0],
                "direction": ["0.1 * (v.particle_random_1 - 0.5) * (4 * math.clamp(q.entity_size / 2, 1, 3) - v.particle_age)", 1, "0.1 * (v.particle_random_2 - 0.5) * (4 * math.clamp(q.entity_size / 2, 1, 3) - v.particle_age)"]
            },
            "minecraft:particle_lifetime_expression": {
                "max_lifetime": "2 * math.clamp(q.entity_size / 2, 1, 3) + 0.5 * v.particle_random_4"
            },
            "minecraft:particle_initial_speed": "(5 + 2 * v.particle_random_3) * math.clamp(q.entity_size / 2, 1, 3)",
            "minecraft:particle_motion_dynamic": {
                "linear_acceleration": [0, -12, 0],
                "linear_drag_coefficient": 0.2
            },
            "minecraft:particle_appearance_billboard": {
                "size": ["0.2 * math.clamp(q.entity_size / 4, 1, 2)", "0.2 * math.clamp(q.entity_size / 4, 1, 2)"],
                "facing_camera_mode": "rotate_xyz",
                "uv": {
                    "texture_width": 16,
                    "texture_height": 128,
                    "flipbook": {
                        "base_UV": [0, "v.particle_random_4 > 0.5 ? 0 : 112"],
                        "size_UV": [16, 16],
                        "step_UV": [0, "v.particle_random_4 > 0.5 ? 16 : -16"],
                        "frames_per_second": 32,
                        "max_frame": 8,
                        "loop": true
                    }
                }
            },
            "minecraft:particle_motion_collision": {
                "collision_drag": 4,
                "coefficient_of_restitution": 0.4,
                "collision_radius": 0.2
            },
            "minecraft:particle_appearance_tinting": {
                "color": [1, 1, 1, 1]
            }
        }
    }
}