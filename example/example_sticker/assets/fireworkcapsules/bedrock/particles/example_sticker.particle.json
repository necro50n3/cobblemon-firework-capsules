{
    "format_version": "1.10.0",
    "particle_effect": {
        "description": {
            "identifier": "fireworkcapsules:example_sticker",
            "basic_render_parameters": {
                "material": "particles_alpha",
                "texture": "fireworkcapsules:textures/particles/example_sticker"
            }
        },
        "components": {
            "minecraft:emitter_rate_steady": {
                "spawn_rate": "30 * math.clamp(q.entity_size / 1.5, 1, 4)",
