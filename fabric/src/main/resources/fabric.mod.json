{
    "schemaVersion": 1,
    "id": "${archives_name}",
    "version": "${version}",
    "name": "${display_name}",
    "description": "${description}",
    "authors": [
        "NecroSo1"
    ],
    "license": "MIT License",
    "icon": "assets/fireworkcapsules/icon.png",
    "environment": "*",
    "entrypoints": {
        "main": [
            "com.necro.fireworkcapsules.fabric.FireworkCapsulesFabric"
        ],
        "client": [
            "com.necro.fireworkcapsules.fabric.FireworkCapsulesFabricClient"
        ],
        "jei_mod_plugin": [
            "com.necro.fireworkcapsules.common.compat.jei.FireworkCapsulesJEIPlugin"
        ],
        "rei_client": [
            "com.necro.fireworkcapsules.common.compat.rei.FireworkCapsulesREIPlugin"
        ],
        "emi": [
            "com.necro.fireworkcapsules.common.compat.emi.FireworkCapsulesEMIPlugin"
        ]
    },
    "mixins": [
        "${archives_name}-common.mixins.json",
        "${archives_name}-fabric.mixins.json"
    ],
    "depends": {
        "minecraft": "${minecraft_version}",
        "cobblemon": ">=${cobblemon_version}"
    }
}